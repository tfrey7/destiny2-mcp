{
  "name": "destiny2-mcp",
  "version": "1.0.0",
  "description": "MCP server for the Destiny 2 (Bungie.net) API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "auth": "tsx src/auth-cli.ts",
    "start": "tsx src/index.ts",
    "scrape:builds": "tsx scripts/scrape-builds.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@resvg/resvg-js": "^2.6.2",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.4.5",
    "selfsigned": "^2.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-promise": "^7.3.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.61.0"
  },
  "private": true
}
