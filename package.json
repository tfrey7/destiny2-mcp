{
  "name": "destiny2-mcp",
  "version": "1.6.1",
  "description": "MCP server for the Destiny 2 (Bungie.net) API",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "auth": "tsx src/setup/auth_cli.ts",
    "start": "tsx src/index.ts",
    "pack:mcpb": "bash scripts/build_mcpb.sh",
    "pack:mcpb:debug": "MCPB_DEBUG=1 bash scripts/build_mcpb.sh",
    "scrape:builds": "tsx scripts/scrape_builds.ts",
    "preview:weapon": "tsx scripts/weapon/preview.ts",
    "preview:armor": "tsx scripts/armor/preview.ts",
    "build:triumphs": "tsx scripts/triumphs/build_index.ts",
    "build:godrolls": "tsx scripts/godrolls/build_index.ts",
    "extract:test_manifest": "tsx scripts/extract_test_manifest.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "adm-zip": "^0.5.17",
    "dotenv": "^16.4.5",
    "selfsigned": "^2.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-unicorn": "^65.0.1",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "private": true
}
